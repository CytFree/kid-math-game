// emoji -> icon key mapping using surrogate pairs
var EM = {};
EM['🍎'] = 'apple'; EM['🍊'] = 'apple';
EM['\uD83D\uDC31'] = 'cat'; EM['\uD83D\uDC36'] = 'dog';
EM['\uD83C\uDF38'] = 'flower'; EM['\uD83C\uDF53'] = 'strawberry';
EM['\uD83C\uDF88'] = 'balloon'; EM['\uD83E\uDD8B'] = 'butterfly';
EM['\uD83C\uDF6A'] = 'cookie'; EM['\uD83C\uDF6C'] = 'candy';
EM['\uD83D\uDC1F'] = 'fish'; EM['\uD83C\uDF81'] = 'gift';
EM['\uD83C\uDF55'] = 'pizza'; EM['\uD83C\uDF66'] = 'icecream';
EM['\uD83D\uDC25'] = 'chick'; EM['\uD83D\uDC23'] = 'egg';
EM['\uD83D\uDC24'] = 'chick'; EM['\uD83D\uDC30'] = 'rabbit';
EM['\uD83E\uDD8A'] = 'fox'; EM['\uD83D\uDC3C'] = 'panda';
EM['\uD83D\uDC28'] = 'koala'; EM['\uD83E\uDD81'] = 'lion';
EM['\uD83D\uDC2F'] = 'tiger'; EM['\uD83D\uDC3B'] = 'bear';
EM['\uD83D\uDC32'] = 'dragon'; EM['\uD83E\uDD84'] = 'unicorn';
EM['\uD83D\uDC09'] = 'dragon'; EM['\uD83D\uDC19'] = 'octopus';
EM['\uD83D\uDC20'] = 'tropicalfish'; EM['\uD83E\uDD88'] = 'shark';
EM['\uD83D\uDC51'] = 'crown'; EM['\uD83C\uDF1F'] = 'star';
EM['\uD83D\uDC8E'] = 'diamond'; EM['\uD83D\uDE0B'] = 'cookie';
EM['\uD83D\uDCA8'] = 'wind';

function icon(key, size) {
  var s = size || 'gi-md';
  return '<span class="gi ' + s + '">' + (GI[key] || '') + '</span>';
}

function chToHTML(ch, size) {
  var key = EM[ch];
  if (key) return icon(key, size);
  return ch;
}

function strToHTML(str, size) {
  var r = '', chars = [...str];
  for (var i = 0; i < chars.length; i++) {
    if (chars[i].trim()) r += chToHTML(chars[i], size);
  }
  return r;
}

function renderIcons(str, size) {
  return str.replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]|[\u2600-\u27BF]|[\uFE00-\uFE0F]/g, function(m) {
    return chToHTML(m, size) || m;
  });
}

// ====== 音效 ======
var AudioCtx = window.AudioContext || window.webkitAudioContext;
var audioCtx;
function getAudioCtx() { if (!audioCtx) audioCtx = new AudioCtx(); return audioCtx; }
function playSound(type) {
  try {
    var ctx = getAudioCtx();
    if (type === 'correct') {
      [523,659,784].forEach(function(f,i){
        var o=ctx.createOscillator(),g=ctx.createGain();
        o.connect(g);g.connect(ctx.destination);o.type='sine';
        o.frequency.setValueAtTime(f,ctx.currentTime+i*0.1);
        g.gain.setValueAtTime(0.3,ctx.currentTime+i*0.1);
        g.gain.exponentialRampToValueAtTime(0.01,ctx.currentTime+i*0.1+0.15);
        o.start(ctx.currentTime+i*0.1);o.stop(ctx.currentTime+i*0.1+0.15);
      });
    } else if (type==='wrong') {
      var o2=ctx.createOscillator(),g2=ctx.createGain();
      o2.connect(g2);g2.connect(ctx.destination);o2.type='sawtooth';
      o2.frequency.setValueAtTime(200,ctx.currentTime);
      o2.frequency.setValueAtTime(150,ctx.currentTime+0.15);
      g2.gain.setValueAtTime(0.2,ctx.currentTime);
      g2.gain.exponentialRampToValueAtTime(0.01,ctx.currentTime+0.3);
      o2.start(ctx.currentTime);o2.stop(ctx.currentTime+0.3);
    } else if (type==='levelup') {
      [523,587,659,698,784,880,988,1047].forEach(function(f,i){
        var o3=ctx.createOscillator(),g3=ctx.createGain();
        o3.connect(g3);g3.connect(ctx.destination);o3.type='sine';
        o3.frequency.setValueAtTime(f,ctx.currentTime+i*0.1);
        g3.gain.setValueAtTime(0.2,ctx.currentTime+i*0.1);
        g3.gain.exponentialRampToValueAtTime(0.01,ctx.currentTime+i*0.1+0.15);
        o3.start(ctx.currentTime+i*0.1);o3.stop(ctx.currentTime+i*0.1+0.15);
      });
    } else if (type==='click') {
      var o4=ctx.createOscillator(),g4=ctx.createGain();
      o4.connect(g4);g4.connect(ctx.destination);o4.type='sine';
      o4.frequency.setValueAtTime(800,ctx.currentTime);
      g4.gain.setValueAtTime(0.1,ctx.currentTime);
      g4.gain.exponentialRampToValueAtTime(0.01,ctx.currentTime+0.05);
      o4.start(ctx.currentTime);o4.stop(ctx.currentTime+0.05);
    } else if (type==='appear') {
      var o5=ctx.createOscillator(),g5=ctx.createGain();
      o5.connect(g5);g5.connect(ctx.destination);o5.type='sine';
      o5.frequency.setValueAtTime(600+Math.random()*400,ctx.currentTime);
      g5.gain.setValueAtTime(0.15,ctx.currentTime);
      g5.gain.exponentialRampToValueAtTime(0.01,ctx.currentTime+0.2);
      o5.start(ctx.currentTime);o5.stop(ctx.currentTime+0.2);
    }
  } catch(e) {}
}

