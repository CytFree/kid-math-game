  { level:6, title:'数学大冒险家', xpNeeded:30, pets:['octopus','',''] },
  { level:7, title:'终极数学大师', xpNeeded:50, pets:['crown','','diamond'] },
];

var SCENES = {
  add: ['apple','apple','cat','dog','flower','strawberry','balloon','butterfly'],
  sub: ['cookie','candy','fish','gift','pizza','icecream']
};

var PRAISES = ['太棒了！','你好聪明！','答对啦！','好厉害！','真棒！','非常好！','天才！','666！','哇塞！','超厉害！','棒呆了！','无敌了！'];
var WRONG_MSGS = ['差一点点哦！','再想想～','没关系！','接近了！','加油！','下次一定！'];

// ====== 状态 ======
var gameState = { mode:'add', xp:0, level:1, totalXp:0, combo:0, maxCombo:0, collection:[], currentAnswer:null, answered:false, totalCorrect:0 };
var learnState = { type:'add', lessonIdx:0, stepIdx:0, answered:false };

var homeScreen = document.getElementById('homeScreen');
var learnScreen = document.getElementById('learnScreen');
var gameScreen = document.getElementById('gameScreen');
var learnVisual = document.getElementById('learnVisual');
var learnText = document.getElementById('learnText');
var learnHint = document.getElementById('learnHint');
var learnNextBtn = document.getElementById('learnNextBtn');
var learnProgress = document.getElementById('learnProgress');

// ====== 页面切换 ======
function showScreen(screen) {
  homeScreen.style.display = 'none';
  learnScreen.classList.remove('show');
  gameScreen.classList.remove('show');
  if (screen === 'home') homeScreen.style.display = 'block';
  else screen.classList.add('show');
}
function goHome() { playSound('click'); showScreen('home'); }

// ====== 初始化首页 ======
function initHome() {
  document.getElementById('homeCardAdd').innerHTML = icon('apple','gi-md') + ' <span style="font-size:32px;color:#e53935;font-weight:bold">+</span> ' + icon('apple','gi-md');
  document.getElementById('homeCardSub').innerHTML = icon('cookie','gi-md') + ' <span style="font-size:32px;color:#e53935;font-weight:bold">-</span>';
}

// ====== 学习模式 ======
function enterLearn(type) {
  playSound('click');
  learnState.type = type; learnState.lessonIdx = 0; learnState.stepIdx = 0; learnState.answered = false;
  document.getElementById('learnTitle').textContent = type === 'add' ? '学习加法' : '学习减法';
  showScreen(learnScreen);
  renderLesson();
}

function renderLesson() {
  var lessons = LESSONS[learnState.type];
  var lesson = lessons[learnState.lessonIdx];
  var totalSteps = lesson.steps ? lesson.steps.length : 1;
  learnProgress.innerHTML = '';
  for (var i = 0; i < totalSteps; i++) {
    var dot = document.createElement('div');
    dot.className = 'progress-dot';
    if (i < learnState.stepIdx) dot.classList.add('done');
    if (i === learnState.stepIdx) dot.classList.add('active');
    learnProgress.appendChild(dot);
  }
  if (lesson.type === 'concept') renderConceptStep(lesson);
  else renderPracticeStep(lesson);
}

function renderConceptStep(lesson) {
  var step = lesson.steps[learnState.stepIdx];
  var isLast = learnState.stepIdx >= lesson.steps.length - 1;
  learnVisual.innerHTML = '';
  var group = document.createElement('div');
  group.className = 'learn-emoji-group';
  var chars = [...step.emoji];
  for (var i = 0; i < chars.length; i++) {
    var span = document.createElement('span');
    span.className = 'learn-emoji';
    span.innerHTML = chToHTML(chars[i], 'gi-lg');
    group.appendChild(span);
    (function(s, idx) {
      setTimeout(function() { s.classList.add('show'); playSound('appear'); }, idx * 300);
    })(span, i);
  }
  learnVisual.appendChild(group);
  learnText.innerHTML = step.text;
  if (lesson.hint && learnState.stepIdx === 0) {
    learnHint.style.display = 'block';
    learnHint.innerHTML = renderIcons(lesson.hint, 'gi-sm');
  } else {
    learnHint.style.display = 'none';
  }
  learnNextBtn.textContent = isLast ? '下一课' : '下一个';
  learnNextBtn.className = 'learn-nav-btn next';
  learnNextBtn.onclick = learnNext;
}

function renderPracticeStep(lesson) {
  learnState.answered = false;
  var answer = lesson.a + (learnState.type === 'add' ? lesson.b : -lesson.b);
  learnState.practiceAnswer = answer;
  learnVisual.innerHTML = '';
  var hintDiv = document.createElement('div');
  hintDiv.style.cssText = 'font-size:35px; text-align:center; line-height:1.6;';
  if (learnState.type === 'add') {
    var eArr = ['strawberry','','','',''][learnState.lessonIdx % 5];
    var html = '';
    for (var i = 0; i < lesson.a; i++) html += icon(eArr, 'gi-md');
    html += ' <span style="font-size:30px">+</span> ';
    for (var i = 0; i < lesson.b; i++) html += icon(eArr, 'gi-md');
    hintDiv.innerHTML = html;
  } else {
    var eArr2 = ['candy','','',''][learnState.lessonIdx % 4];
    var html2 = '';
    for (var i = 0; i < lesson.a; i++) html2 += icon(eArr2, 'gi-md');
    hintDiv.innerHTML = html2;
  }
  learnVisual.appendChild(hintDiv);
  learnText.innerHTML = lesson.text;
  learnHint.style.display = 'block';
  learnHint.innerHTML = renderIcons(lesson.hint, 'gi-sm');
  var numpadDiv = document.createElement('div');
  numpadDiv.className = 'numpad';
  numpadDiv.style.marginTop = '15px';
  var colors = ['#ff6b6b','#ffa726','#ffee58','#66bb6a','#42a5f5','#ab47bc','#26c6da','#ef5350','#ffa726','#ffee58','#66bb6a'];
  for (var i = 0; i <= 10; i++) {
    var btn = document.createElement('button');
    btn.className = 'num-btn';
    btn.textContent = i;
    btn.style.height = '50px';
    btn.style.fontSize = '22px';
    btn.style.background = 'linear-gradient(145deg, ' + colors[i] + ', ' + darken(colors[i]) + ')';
    (function(n, l, b) { btn.onclick = function() { checkLearnAnswer(n, l, b); }; })(i, lesson, btn);
    numpadDiv.appendChild(btn);
  }
  learnVisual.appendChild(numpadDiv);
  learnNextBtn.style.display = 'none';
}

function checkLearnAnswer(num, lesson, btn) {
  if (learnState.answered) return;
  if (num === learnState.practiceAnswer) {
    learnState.answered = true;
    playSound('correct');
    btn.style.background = 'linear-gradient(145deg, #66bb6a, #2e7d32)';
    var np = learnVisual.querySelector('.numpad');
    if (np) np.style.display = 'none';
    learnText.innerHTML = lesson.text.replace(/\?/g, '<span class="result">' + learnState.practiceAnswer + '</span>');
    learnHint.innerHTML = '答对了！太棒了！';
    learnHint.style.background = '#e8f5e9';
    learnHint.style.color = '#2e7d32';
    learnNextBtn.style.display = '';
    learnNextBtn.textContent = learnState.lessonIdx < LESSONS[learnState.type].length - 1 ? '下一课' : '去闯关！';
    learnNextBtn.className = learnState.lessonIdx < LESSONS[learnState.type].length - 1 ? 'learn-nav-btn next' : 'learn-nav-btn start-game';
    learnNextBtn.onclick = function() {
      if (learnState.lessonIdx >= LESSONS[learnState.type].length - 1) enterGame();
      else learnNext();
    };
  } else {
    playSound('wrong');
    btn.style.background = 'linear-gradient(145deg, #ef5350, #c62828)';
    btn.style.transform = 'scale(0.9)';
    setTimeout(function() { btn.style.background = ''; btn.style.transform = ''; }, 500);
    learnState.answered = true;
    var np2 = learnVisual.querySelector('.numpad');
    if (np2) np2.style.display = 'none';
    learnHint.innerHTML = '不对哦，正确答案是 <strong>' + learnState.practiceAnswer + '</strong>，记住啦！';
    learnHint.style.background = '#fff3e0';
    learnHint.style.color = '#e65100';
    learnNextBtn.style.display = '';
    learnNextBtn.textContent = learnState.lessonIdx < LESSONS[learnState.type].length - 1 ? '下一课' : '去闯关！';
    learnNextBtn.className = learnState.lessonIdx < LESSONS[learnState.type].length - 1 ? 'learn-nav-btn next' : 'learn-nav-btn start-game';
    learnNextBtn.onclick = function() {
      if (learnState.lessonIdx >= LESSONS[learnState.type].length - 1) enterGame();
      else learnNext();
    };
  }
}

function learnNext() {
  playSound('click');
  var lessons = LESSONS[learnState.type];
  var lesson = lessons[learnState.lessonIdx];
  if (lesson.type === 'concept') {
    if (learnState.stepIdx < lesson.steps.length - 1) { learnState.stepIdx++; renderLesson(); }
    else if (learnState.lessonIdx < lessons.length - 1) { learnState.lessonIdx++; learnState.stepIdx = 0; renderLesson(); }
  } else {
    if (learnState.lessonIdx < lessons.length - 1) { learnState.lessonIdx++; learnState.stepIdx = 0; learnState.answered = false; learnNextBtn.style.display = ''; renderLesson(); }
  }
}

function learnPrev() {
  playSound('click');
  var lessons = LESSONS[learnState.type];
  var lesson = lessons[learnState.lessonIdx];
  if (lesson.type === 'concept' && learnState.stepIdx > 0) { learnState.stepIdx--; renderLesson(); }
  else if (lesson.type === 'concept' && learnState.stepIdx === 0 && learnState.lessonIdx > 0) {
    learnState.lessonIdx--;
    var prev = lessons[learnState.lessonIdx];
    learnState.stepIdx = prev.steps ? prev.steps.length - 1 : 0;
    learnState.answered = false; learnNextBtn.style.display = ''; renderLesson();
  }
  else if (lesson.type === 'practice' && learnState.lessonIdx > 0) {
    learnState.lessonIdx--; learnState.stepIdx = 0; learnState.answered = false; learnNextBtn.style.display = ''; renderLesson();
  }
}

// ====== 游戏模式 ======
function enterGame() { playSound('click'); showScreen(gameScreen); initGame(); }

function initGame() {
  initStars(); initNumpad(); initCollectionBar(); generateQuestion(); updateDisplay();
  var chips = document.querySelectorAll('.mode-chip');
  for (var i = 0; i < chips.length; i++) {
    (function(btn) {
      var nb = btn.cloneNode(true);
      btn.parentNode.replaceChild(nb, btn);
      nb.onclick = function() {
        playSound('click');
        document.querySelectorAll('.mode-chip').forEach(function(b){b.classList.remove('active');});
        nb.classList.add('active');
        gameState.mode = nb.dataset.mode;
        gameState.combo = 0;
        document.getElementById('comboDisplay').textContent = '';
        generateQuestion();
      };
    })(chips[i]);
  }
}

function initStars() {
  var c = document.getElementById('starsBg');
  if (c.children.length > 0) return;
  for (var i = 0; i < 30; i++) {
    var s = document.createElement('div');
    s.className = 'star-particle';
    s.style.left = Math.random()*100+'%';
    s.style.top = Math.random()*100+'%';
    s.style.animationDelay = Math.random()*2+'s';
    c.appendChild(s);
  }
}

function initNumpad() {
  var el = document.getElementById('numpad');
  if (el.children.length > 0) return;
  var colors = ['#ff6b6b','#ffa726','#ffee58','#66bb6a','#42a5f5','#ab47bc','#26c6da','#ef5350','#ffa726','#ffee58','#66bb6a'];
  for (var i = 0; i <= 10; i++) {
    var btn = document.createElement('button');
    btn.className = 'num-btn';
    btn.textContent = i;
    btn.style.background = 'linear-gradient(145deg, ' + colors[i] + ', ' + darken(colors[i]) + ')';
    (function(n){ btn.onclick = function(){ checkAnswer(n); }; })(i);
    el.appendChild(btn);
  }
}

function darken(c) { return c.replace(/[a-f0-9]{2}$/gi, function(m){return Math.max(0,parseInt(m,16)-40).toString(16).padStart(2,'0');}); }

function initCollectionBar() {
  var el = document.getElementById('collectionBar');
  el.innerHTML = '';
  for (var i = 0; i < gameState.collection.length; i++) {
    var slot = document.createElement('div');
    slot.className = 'pet-slot';
    slot.innerHTML = icon(gameState.collection[i], 'gi-sm');
    el.appendChild(slot);
  }
  for (var j = gameState.collection.length; j < Math.min(20, gameState.collection.length+3); j++) {
    var slot2 = document.createElement('div');
    slot2.className = 'pet-slot empty';
    slot2.textContent = '?';
    el.appendChild(slot2);
  }
}

function generateQuestion() {
  gameState.answered = false;
  document.getElementById('feedback').textContent = '';
  document.getElementById('feedback').style.color = '';
  var mode = gameState.mode;
  if (mode === 'mix') mode = Math.random() < 0.5 ? 'add' : 'sub';
  var maxNum = gameState.level >= 5 ? 10 : gameState.level >= 3 ? 8 : 5;
  var a, b, answer, op;
  if (mode === 'add') { a = Math.floor(Math.random()*(maxNum+1)); b = Math.floor(Math.random()*(maxNum+1-a)); answer = a+b; op = '+'; }
  else { a = Math.floor(Math.random()*(maxNum+1)); b = Math.floor(Math.random()*(a+1)); answer = a-b; op = '-'; }
  gameState.currentAnswer = answer;
  var sceneList = SCENES[mode];
  var sceneKey = sceneList[Math.floor(Math.random()*sceneList.length)];
  var iconStr = icon(sceneKey, 'gi-md');
  if (op === '+') {
    var html = '';
    for (var i = 0; i < a; i++) html += iconStr;
    html += ' <span style="font-size:36px">+</span> ';
    for (var i = 0; i < b; i++) html += iconStr;
    document.getElementById('sceneEmoji').innerHTML = html;
  } else {
    var remaining = a - b;
    var html2 = '';
    for (var i = 0; i < remaining; i++) html2 += iconStr;
    if (b > 0) {
      var crossed = '';
      for (var i = 0; i < b; i++) crossed += iconStr;
      html2 += '<span style="opacity:0.35;text-decoration:line-through">' + crossed + '</span>' + icon('wind', 'gi-sm');
    }
    document.getElementById('sceneEmoji').innerHTML = html2;
  }
  document.getElementById('equation').innerHTML = '<div class="num">'+a+'</div><div class="op">'+op+'</div><div class="num">'+b+'</div><div class="equals">=</div><div class="answer-box" id="answerBox">?</div>';
}

function checkAnswer(num) {
  if (gameState.answered) return;
  gameState.answered = true;
  var box = document.getElementById('answerBox');
  box.textContent = num;
  if (num === gameState.currentAnswer) {
    gameState.totalCorrect++; gameState.combo++;
    if (gameState.combo > gameState.maxCombo) gameState.maxCombo = gameState.combo;
    box.classList.add('correct'); playSound('correct');
    var xpGain = 1 + Math.floor(gameState.combo / 3);
    gameState.xp += xpGain; gameState.totalXp += xpGain;
    document.getElementById('feedback').textContent = PRAISES[Math.floor(Math.random()*PRAISES.length)];
    document.getElementById('feedback').style.color = '#4caf50';
    if (gameState.combo >= 3) document.getElementById('comboDisplay').textContent = '连击 x' + gameState.combo + '！';
    var levelData = LEVELS.find(function(l){return l.level===gameState.level;}) || LEVELS[LEVELS.length-1];
    if (gameState.totalCorrect % 3 === 0) {
      var pet = levelData.pets[Math.floor(Math.random()*levelData.pets.length)];
      gameState.collection.push(pet);
      setTimeout(function(){ spawnEmojiRain(pet); }, 300);
    }
    if (gameState.combo >= 5) createFireworks();
    updateDisplay();
    var nextLevel = LEVELS.find(function(l){return l.level===gameState.level+1;});
    var curLevel = LEVELS.find(function(l){return l.level===gameState.level;}) || LEVELS[0];
    if (gameState.xp >= curLevel.xpNeeded && nextLevel) { gameState.level++; gameState.xp = 0; setTimeout(function(){ showLevelUp(nextLevel); }, 800); }
    setTimeout(generateQuestion, 1500);
  } else {
    gameState.combo = 0;
    document.getElementById('comboDisplay').textContent = '';
    box.classList.add('wrong'); playSound('wrong');
    document.getElementById('feedback').textContent = WRONG_MSGS[Math.floor(Math.random()*WRONG_MSGS.length)] + ' 答案是 ' + gameState.currentAnswer;
    document.getElementById('feedback').style.color = '#f44336';
    updateDisplay();
    setTimeout(function(){
      box.classList.remove('wrong'); gameState.answered = false; box.textContent = '?';
      document.getElementById('feedback').textContent = '再试试看！';
      document.getElementById('feedback').style.color = '#ff9800';
    }, 2500);
  }
}

function updateDisplay() {
  var cur = LEVELS.find(function(l){return l.level===gameState.level;}) || LEVELS[0];
  document.getElementById('xpFill').style.width = Math.min(100, (gameState.xp / cur.xpNeeded) * 100) + '%';
  document.getElementById('levelDisplay').textContent = 'Lv.' + gameState.level;
  document.getElementById('scoreDisplay').textContent = gameState.totalXp;
  initCollectionBar();
}

function showLevelUp(lv) {
  playSound('levelup');
  document.getElementById('levelupTitle').textContent = '升级到 Lv.' + lv.level + '！';
  document.getElementById('levelupNewTitle').textContent = '称号：' + lv.title;
  document.getElementById('levelupModal').classList.add('show');
  createFireworks();
}
function closeLevelUp() { document.getElementById('levelupModal').classList.remove('show'); playSound('click'); }

function createFireworks() {
  var colors = ['#ff6b6b','#ffd93d','#6bcb77','#4d96ff','#ff6f00','#ab47bc'];
  for (var f = 0; f < 3; f++) {
    (function(ff){
      setTimeout(function(){
        var cx = Math.random()*window.innerWidth;
        var cy = Math.random()*(window.innerHeight/2);
        for (var i = 0; i < 15; i++) {
          var p = document.createElement('div');
          p.className = 'firework-particle';
          p.style.left = cx+'px'; p.style.top = cy+'px';
          p.style.background = colors[Math.floor(Math.random()*colors.length)];
          var angle = (Math.PI*2/15)*i;
          var dist = 80 + Math.random()*60;
          p.animate([{transform:'translate(0,0) scale(1)',opacity:1},{transform:'translate('+Math.cos(angle)*dist+'px,'+Math.sin(angle)*dist+'px) scale(0)',opacity:0}],{duration:1000,easing:'ease-out',fill:'forwards'});
          document.getElementById('fireworks').appendChild(p);
          setTimeout(function(){p.remove();}, 1000);
        }
      }, ff*300);
    })(f);
  }
}

function spawnEmojiRain(key) {
  for (var i = 0; i < 8; i++) {
    (function(ii){
      setTimeout(function(){
        var el = document.createElement('div');
        el.className = 'emoji-rain';
        el.innerHTML = icon(key, 'gi-md');
        el.style.left = Math.random()*90+5+'%';
        document.body.appendChild(el);
        setTimeout(function(){el.remove();}, 2000);
      }, ii*100);
    })(i);
  }
}

// 启动
showScreen('home');
initStars();
initNumpad();
initHome();
</script>
</body>
</html>
